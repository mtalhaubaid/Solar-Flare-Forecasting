# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Local environment and secrets
.env
.env.*
*.pem
*.key

# Training artefacts and logs
outputs/*
!outputs/.gitignore
*.log
*.tmp
*.bak

# Large local datasets and generated data
data/*
!data/.gitignore

# Notebook outputs and checkpoints
*.ipynb_checkpoints
